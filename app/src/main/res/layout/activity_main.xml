<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#FFFFFF">

    <!--    IMAGE PLACE HOLDER-->
    <ImageView
        android:id="@+id/ivPinImage"
        android:layout_width="0dp"
        android:layout_height="240dp"
        android:background="#E0E0E0"
        android:scaleType="centerCrop"
        android:contentDescription="@string/img_placeholder_desc"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_alignParentBottom="true"
        />
    <!-- PIN TITLE-->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/pin_title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        app:layout_constraintTop_toBottomOf="@+id/ivPinImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    <!--DISCRIPTION-->
    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/pin_description"
        android:textSize="15sp"
        android:textColor="#555555"
        android:lineSpacingMultiplier="1.4"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    <!-- SAVE BUTTON-->
    <Button
        android:id="@+id/btnSave"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="8dp"
        android:text="@string/btn_save"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1565C0"
        app:layout_constraintTop_toBottomOf="@+id/tvDescription"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btnShare" />

    <!--SHARE BUTTON-->
    <Button
        android:id="@+id/btnShare"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:layout_marginStart="8dp"
        android:text="@string/btn_share"
        android:textSize="15sp"
        android:textColor="#1565C0"
        android:backgroundTint="#E3F2FD"
        app:layout_constraintTop_toBottomOf="@+id/tvDescription"
        app:layout_constraintStart_toEndOf="@+id/btnSave"
        app:layout_constraintEnd_toEndOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
